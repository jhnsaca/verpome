<script>
gsap.registerPlugin(ScrollTrigger);

// ── CURSOR
const cur=document.getElementById('cursor');
const ring=document.getElementById('cursor-ring');
const lbl=document.getElementById('cursor-label');
let mx=0,my=0,cx=0,cy=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;});
(function tick(){
  cx+=(mx-cx)*.15;cy+=(my-cy)*.15;
  rx+=(mx-rx)*.08;ry+=(my-ry)*.08;
  cur.style.left=cx+'px';cur.style.top=cy+'px';
  ring.style.left=rx+'px';ring.style.top=ry+'px';
  lbl.style.left=(mx+20)+'px';lbl.style.top=my+'px';
  requestAnimationFrame(tick);
})();
document.querySelectorAll('.reel-item,.ig-card,.web-card,.hero-cta,.service-card').forEach(el=>{
  el.addEventListener('mouseenter',()=>document.body.classList.add('hovering'));
  el.addEventListener('mouseleave',()=>document.body.classList.remove('hovering'));
});

// ── CANVAS BACKGROUND — leather texture + mouse light
const canvas=document.getElementById('bg-canvas');
const ctx=canvas.getContext('2d');
let W,H,mLx=.5,mLy=.5,t=0;
function resize(){W=canvas.width=window.innerWidth;H=canvas.height=window.innerHeight;}
resize();window.addEventListener('resize',resize);
document.addEventListener('mousemove',e=>{mLx=e.clientX/W;mLy=e.clientY/H;});

// Perlin noise
const perm=[...Array(256)].map((_,i)=>i).sort(()=>Math.random()-.5);
const p=[...perm,...perm];
function fade(t){return t*t*t*(t*(t*6-15)+10)}
function lerp(t,a,b){return a+t*(b-a)}
function grad(h,x,y){const v=h&3;const u=v<2?x:y,w=v<2?y:x;return((h&1)?-u:u)+((h&2)?-w:w)}
function noise(x,y){
  const X=Math.floor(x)&255,Y=Math.floor(y)&255;
  x-=Math.floor(x);y-=Math.floor(y);
  const u=fade(x),v=fade(y);
  return lerp(v,lerp(u,grad(p[p[X]+Y],x,y),grad(p[p[X+1]+Y],x-1,y)),
                lerp(u,grad(p[p[X]+Y+1],x,y-1),grad(p[p[X+1]+Y+1],x-1,y-1)));
}

function drawBg(){
  t+=.0007;
  // Leather grain — slightly brighter than before
  const id=ctx.createImageData(W,H);
  const d=id.data;
  for(let y=0;y<H;y+=2){
    for(let x=0;x<W;x+=2){
      const n1=noise(x/W*3.5,y/H*3+t)*.5+.5;
      const n2=noise(x/W*7,y/H*5.5+t*.8)*.5+.5;
      const g=n1*.65+n2*.35;
      // Slightly brighter base (+4/5 luminosity)
      const r=Math.floor(12+g*22);
      const gv=Math.floor(12+g*36+8);
      const b=Math.floor(12+g*15);
      for(let dy=0;dy<2&&y+dy<H;dy++){
        for(let dx=0;dx<2&&x+dx<W;dx++){
          const i=((y+dy)*W+(x+dx))*4;
          d[i]=r;d[i+1]=gv;d[i+2]=b;d[i+3]=255;
        }
      }
    }
  }
  ctx.putImageData(id,0,0);
  // Mouse radial light
  const g1=ctx.createRadialGradient(mLx*W,mLy*H,0,mLx*W,mLy*H,Math.max(W,H)*.65);
  g1.addColorStop(0,'rgba(27,74,46,.2)');
  g1.addColorStop(.5,'rgba(9,58,34,.05)');
  g1.addColorStop(1,'rgba(0,0,0,.42)');
  ctx.fillStyle=g1;ctx.fillRect(0,0,W,H);
  // Vignette
  const vg=ctx.createRadialGradient(W/2,H/2,0,W/2,H/2,Math.max(W,H)*.72);
  vg.addColorStop(0,'transparent');
  vg.addColorStop(.55,'rgba(0,0,0,.18)');
  vg.addColorStop(1,'rgba(0,0,0,.68)');
  ctx.fillStyle=vg;ctx.fillRect(0,0,W,H);
  requestAnimationFrame(drawBg);
}
drawBg();

// ── TIMECODE
const tc=document.getElementById('timecode');
let frames=0;
setInterval(()=>{
  frames++;
  const f=frames%30;
  const s=Math.floor(frames/30)%60;
  const m=Math.floor(frames/1800)%60;
  const h=Math.floor(frames/108000);
  tc.textContent=[h,m,s,f].map(v=>String(v).padStart(2,'0')).join(':');
},33);

// ── PRELOADER
const preBar=document.getElementById('preBar');
const prePct=document.getElementById('prePct');
const pre=document.getElementById('preloader');
const letters=pre.querySelectorAll('.pre-logo span');
let pct=0;
gsap.to(letters,{y:0,duration:.55,stagger:.055,ease:'power3.out',delay:.15});
const ldi=setInterval(()=>{
  pct+=Math.random()*5+2;
  if(pct>100)pct=100;
  preBar.style.width=pct+'%';
  prePct.textContent=Math.floor(pct)+'%';
  if(pct>=100){
    clearInterval(ldi);
    setTimeout(()=>{
      gsap.to(pre,{opacity:0,duration:.7,ease:'power2.inOut',onComplete:()=>{
        pre.style.display='none';
        initPage();
      }});
    },280);
  }
},50);

function initPage(){
  gsap.to('.nav-logo',{opacity:1,duration:.9,ease:'power2.out'});
  gsap.to('.hero-eyebrow',{opacity:1,y:0,duration:.9,delay:.25,ease:'power3.out'});
  gsap.to('.hero-title .line span',{y:0,duration:1.1,stagger:.1,ease:'power4.out',delay:.4});
  gsap.to('.hero-bottom',{opacity:1,y:0,duration:.9,delay:.9,ease:'power3.out'});
  gsap.to('.hero-studio-badge',{opacity:1,duration:.8,delay:1.2,ease:'power2.out'});
  gsap.to('.hero-timecode',{opacity:1,duration:.8,delay:1.4,ease:'power2.out'});

  gsap.utils.toArray('.reveal').forEach(el=>{
    gsap.to(el,{opacity:1,y:0,duration:.9,ease:'power3.out',
      scrollTrigger:{trigger:el,start:'top 88%'}});
  });
  gsap.utils.toArray('.reveal-left').forEach(el=>{
    gsap.to(el,{opacity:1,x:0,duration:.9,ease:'power3.out',
      scrollTrigger:{trigger:el,start:'top 85%'}});
  });
  gsap.utils.toArray('.reveal-scale').forEach(el=>{
    gsap.to(el,{opacity:1,scale:1,duration:1.1,ease:'power3.out',
      scrollTrigger:{trigger:el,start:'top 85%'}});
  });

  // Services stagger
  gsap.utils.toArray('.service-card').forEach((c,i)=>{
    gsap.fromTo(c,{opacity:0,y:44},{opacity:1,y:0,duration:.8,ease:'power3.out',delay:i*.09,
      scrollTrigger:{trigger:'#services',start:'top 75%'}});
  });
  // Founder parallax
  gsap.to('.founder-right',{y:-50,ease:'none',
    scrollTrigger:{trigger:'#founder',start:'top bottom',end:'bottom top',scrub:1.2}});
  // Hero parallax
  gsap.to('.hero-title',{y:70,ease:'none',
    scrollTrigger:{trigger:'#hero',start:'top top',end:'bottom top',scrub:.8}});
}

// ── TABS
document.querySelectorAll('.tab-btn').forEach(btn=>{
  btn.addEventListener('click',()=>{
    document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
    document.querySelectorAll('.portfolio-panel').forEach(p=>p.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('tab-'+btn.dataset.tab).classList.add('active');
    // Re-trigger reveal for newly shown items
    gsap.fromTo('#tab-'+btn.dataset.tab+' .reveal',
      {opacity:0,y:28},{opacity:1,y:0,duration:.7,stagger:.06,ease:'power3.out'});
  });
});

// ── LIGHTBOX
const lb=document.getElementById('lightbox');
const lbClose=document.getElementById('lbClose');
const lbTitle=document.getElementById('lbTitle');
const lbType=document.getElementById('lbType');
const lbPh=document.getElementById('lbPlaceholder');

document.querySelectorAll('.reel-item').forEach(item=>{
  item.addEventListener('click',()=>{
    lbTitle.textContent=item.dataset.title||'Untitled';
    lbType.textContent=item.dataset.type||'';
    lbPh.textContent='Video asset coming soon.\nDrop your footage here.';
    lb.classList.add('open');
  });
});
lbClose.addEventListener('click',()=>lb.classList.remove('open'));
lb.addEventListener('click',e=>{if(e.target===lb)lb.classList.remove('open');});

// ── SMOOTH SCROLL
document.querySelectorAll('a[href^="#"]').forEach(a=>{
  a.addEventListener('click',e=>{
    e.preventDefault();
    const t=document.querySelector(a.getAttribute('href'));
    if(t)t.scrollIntoView({behavior:'smooth'});
  });
});
</script>
