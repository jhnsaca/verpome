<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Verpome Studio — Visual Intelligence</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,300;0,400;0,700;1,300;1,400;1,700&family=Jost:wght@200;300;400;500&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --green:#093A22;--green2:#1B4A2E;--green3:#2a6642;
  --cream:#F4F1EB;--cream2:#e8e4dc;
  --metal:#8D8880;--gold:#c9a96e;
}
html{overflow-x:hidden;scroll-behavior:smooth}
body{
  background:#071510;
  color:var(--cream);
  font-family:'Jost',sans-serif;
  font-weight:300;
  cursor:none;
  overflow-x:hidden;
}

/* ── CURSOR ── */
#cursor{
  position:fixed;width:10px;height:10px;border-radius:50%;
  background:var(--cream);pointer-events:none;z-index:9999;
  transform:translate(-50%,-50%);mix-blend-mode:difference;
  transition:width .3s cubic-bezier(.16,1,.3,1),height .3s cubic-bezier(.16,1,.3,1);
}
#cursor-ring{
  position:fixed;width:40px;height:40px;
  border:1px solid rgba(244,241,235,.3);border-radius:50%;
  pointer-events:none;z-index:9998;transform:translate(-50%,-50%);
  transition:width .4s cubic-bezier(.16,1,.3,1),height .4s cubic-bezier(.16,1,.3,1),border-color .3s;
}
#cursor-label{
  position:fixed;font-family:'Jost',sans-serif;font-size:8px;letter-spacing:.2em;text-transform:uppercase;
  color:var(--cream);pointer-events:none;z-index:9997;opacity:0;
  transform:translate(16px,-50%);white-space:nowrap;transition:opacity .3s;
}
body.hovering #cursor{width:5px;height:5px}
body.hovering #cursor-ring{width:64px;height:64px;border-color:rgba(244,241,235,.55)}
body.hovering #cursor-label{opacity:1}

/* ── CANVAS BG ── */
#bg-canvas{position:fixed;inset:0;z-index:0;pointer-events:none;}

/* ── GRAIN ── */
.grain{
  position:fixed;inset:0;z-index:700;pointer-events:none;opacity:.65;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.05'/%3E%3C/svg%3E");
}

/* ── PRELOADER ── */
#preloader{
  position:fixed;inset:0;z-index:9000;
  background:#071510;
  display:flex;flex-direction:column;align-items:center;justify-content:center;gap:32px;
}
.pre-tag{
  font-size:8px;letter-spacing:.45em;text-transform:uppercase;
  color:rgba(244,241,235,.28);margin-bottom:8px;
}
.pre-logo{
  font-family:'Playfair Display',serif;
  font-size:clamp(40px,9vw,88px);font-weight:300;letter-spacing:.35em;
  color:var(--cream);overflow:hidden;display:flex;
}
.pre-logo span{display:inline-block;transform:translateY(110%)}
.pre-bar-wrap{width:180px;height:1px;background:rgba(244,241,235,.1)}
.pre-bar{height:100%;background:var(--cream);width:0%;transition:width .1s linear}
.pre-pct{font-size:8px;letter-spacing:.32em;color:rgba(244,241,235,.32)}
.pre-studio{
  font-size:9px;letter-spacing:.4em;text-transform:uppercase;
  color:rgba(244,241,235,.2);
}

/* ── NAV ── */
nav{
  position:fixed;top:0;left:0;right:0;z-index:800;
  padding:32px 60px;
  display:flex;justify-content:space-between;align-items:center;
}
.nav-logo{
  font-family:'Playfair Display',serif;font-size:12px;letter-spacing:.5em;text-transform:uppercase;
  color:var(--cream);opacity:0;
}
.nav-links{display:flex;gap:40px;list-style:none}
.nav-links a{
  font-size:8px;letter-spacing:.22em;text-transform:uppercase;
  color:rgba(244,241,235,.38);text-decoration:none;cursor:none;transition:color .3s;
}
.nav-links a:hover{color:var(--cream)}

/* ── HERO — mirrored from main verpome site ── */
#hero{
  position:relative;min-height:100vh;z-index:5;
  display:flex;flex-direction:column;justify-content:flex-end;
  padding:0 10vw 8vh;
  /* Studio atmosphere: scanlines overlay */
}
/* Studio HUD lines — subtle monitor effect */
#hero::before{
  content:'';position:absolute;inset:0;pointer-events:none;z-index:2;
  background:repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(244,241,235,.008) 3px,rgba(244,241,235,.008) 4px);
}
/* Corner brackets */
#hero::after{
  content:'';position:absolute;
  top:80px;left:10vw;right:10vw;bottom:8vh;
  border:1px solid rgba(244,241,235,.04);
  pointer-events:none;z-index:2;
}

.hero-studio-badge{
  position:absolute;top:120px;right:10vw;z-index:3;
  display:flex;align-items:center;gap:10px;
  opacity:0;
}
.hero-badge-dot{
  width:6px;height:6px;border-radius:50%;background:var(--gold);
  animation:badgePulse 2.5s ease-in-out infinite;
}
@keyframes badgePulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(.7)}}
.hero-badge-txt{font-size:8px;letter-spacing:.28em;text-transform:uppercase;color:rgba(244,241,235,.35)}

.hero-eyebrow{
  font-size:8px;letter-spacing:.42em;text-transform:uppercase;
  color:rgba(244,241,235,.32);margin-bottom:32px;
  opacity:0;transform:translateY(16px);position:relative;z-index:3;
}

.hero-title{
  font-family:'Playfair Display',serif;
  font-size:clamp(72px,12vw,172px);
  font-weight:300;line-height:.92;letter-spacing:-.015em;
  margin-bottom:52px;position:relative;z-index:3;
}
.hero-title .line{overflow:hidden;display:block}
.hero-title .line span{display:block;transform:translateY(110%)}
.hero-title .outline{-webkit-text-stroke:1px var(--cream);color:transparent}

/* Timecode — studio aesthetic */
.hero-timecode{
  position:absolute;bottom:8vh;right:10vw;z-index:3;
  font-family:'Jost',sans-serif;font-size:9px;letter-spacing:.15em;
  color:rgba(244,241,235,.18);opacity:0;
  font-variant-numeric:tabular-nums;
}

.hero-bottom{
  display:flex;align-items:flex-end;gap:80px;width:100%;
  opacity:0;transform:translateY(16px);position:relative;z-index:3;
}
.hero-desc{
  font-size:11px;line-height:2;letter-spacing:.04em;
  color:rgba(244,241,235,.45);max-width:320px;
}
.hero-cta{
  display:inline-flex;align-items:center;gap:14px;
  font-size:8px;letter-spacing:.22em;text-transform:uppercase;
  color:var(--cream);border:1px solid rgba(244,241,235,.2);
  padding:15px 30px;text-decoration:none;cursor:none;
  transition:border-color .4s,gap .4s;
}
.hero-cta:hover{border-color:var(--cream);gap:22px}
.hero-scroll{margin-left:auto;display:flex;flex-direction:column;align-items:center;gap:10px}
.hero-scroll-line{
  width:1px;height:52px;
  background:linear-gradient(to bottom,rgba(244,241,235,.6),transparent);
  animation:scrollLine 2.4s ease-in-out infinite;
}
@keyframes scrollLine{0%,100%{opacity:.7;transform:scaleY(1)}50%{opacity:.2;transform:scaleY(.5)}}
.hero-scroll-txt{font-size:7px;letter-spacing:.3em;text-transform:uppercase;color:rgba(244,241,235,.25);writing-mode:vertical-lr}

/* ── MARQUEE ── */
.marquee-wrap{
  position:relative;z-index:5;overflow:hidden;
  border-top:1px solid rgba(244,241,235,.07);
  border-bottom:1px solid rgba(244,241,235,.07);
  padding:18px 0;background:rgba(244,241,235,.015);
}
.marquee-track{display:flex;animation:marqueeRun 30s linear infinite;white-space:nowrap}
.marquee-item{
  font-family:'Playfair Display',serif;font-style:italic;
  font-size:clamp(13px,1.6vw,19px);color:rgba(244,241,235,.2);
  padding:0 44px;letter-spacing:.04em;flex-shrink:0;
}
.marquee-dot{color:var(--gold);font-style:normal;opacity:.55}
@keyframes marqueeRun{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* ── SECTION BASE ── */
section{position:relative;z-index:5}
.section-label{font-size:8px;letter-spacing:.42em;text-transform:uppercase;color:rgba(244,241,235,.25);margin-bottom:20px}

/* ── FOUNDER ── */
#founder{padding:160px 10vw;display:grid;grid-template-columns:1fr 1fr;gap:100px;align-items:center}

.founder-title{
  font-family:'Playfair Display',serif;
  font-size:clamp(42px,5.5vw,78px);font-weight:300;line-height:1.05;margin-bottom:28px;
}
.founder-title em{font-style:italic;color:rgba(244,241,235,.4)}
.founder-text{font-size:11px;line-height:2.1;color:rgba(244,241,235,.52);max-width:440px}
.founder-text+.founder-text{margin-top:18px}

/* Countries strip — replaces stats */
.founder-countries{
  display:flex;flex-wrap:wrap;gap:8px;margin-top:44px;
}
.country-tag{
  font-size:8px;letter-spacing:.22em;text-transform:uppercase;
  border:1px solid rgba(244,241,235,.12);padding:8px 14px;
  color:rgba(244,241,235,.38);position:relative;overflow:hidden;
  transition:border-color .4s,color .4s;cursor:none;
}
.country-tag::before{
  content:'';position:absolute;inset:0;
  background:rgba(244,241,235,.04);transform:translateX(-100%);
  transition:transform .4s cubic-bezier(.16,1,.3,1);
}
.country-tag:hover{border-color:rgba(244,241,235,.35);color:var(--cream)}
.country-tag:hover::before{transform:none}

.founder-right{
  display:grid;grid-template-columns:1fr 1fr;grid-template-rows:1fr 1fr;
  gap:12px;height:500px;
}
.founder-img{position:relative;overflow:hidden;background:rgba(244,241,235,.04)}
.founder-img:first-child{
  grid-row:span 2;
  clip-path:polygon(0 0,100% 5%,100% 100%,0 95%);
}
.founder-img:nth-child(2){clip-path:polygon(0 0,100% 0,100% 100%,6% 100%)}
.founder-img:nth-child(3){clip-path:polygon(6% 0,100% 0,100% 100%,0 100%)}
.founder-img-inner{
  position:absolute;inset:0;display:flex;align-items:flex-end;padding:18px;
  background:linear-gradient(to top,rgba(7,21,16,.7) 0%,transparent 60%);
}
.founder-img-tag{font-size:7px;letter-spacing:.2em;text-transform:uppercase;color:rgba(244,241,235,.42)}
/* Placeholder city backgrounds */
.city-bkk{background:radial-gradient(ellipse at 40% 60%,rgba(27,74,46,.55),rgba(7,21,16,.95)),repeating-linear-gradient(45deg,transparent,transparent 2px,rgba(244,241,235,.012) 2px,rgba(244,241,235,.012) 4px)}
.city-paris{background:radial-gradient(ellipse at 60% 35%,rgba(141,136,128,.22),rgba(7,21,16,.95)),repeating-linear-gradient(-45deg,transparent,transparent 3px,rgba(244,241,235,.008) 3px,rgba(244,241,235,.008) 6px)}
.city-brasil{background:radial-gradient(ellipse at 30% 65%,rgba(201,169,110,.14),rgba(7,21,16,.95)),repeating-linear-gradient(0deg,transparent,transparent 4px,rgba(244,241,235,.01) 4px,rgba(244,241,235,.01) 8px)}
.city-usa{background:radial-gradient(ellipse at 55% 45%,rgba(42,102,66,.3),rgba(7,21,16,.95)),repeating-linear-gradient(60deg,transparent,transparent 3px,rgba(244,241,235,.01) 3px,rgba(244,241,235,.01) 5px)}

/* ── SERVICES ── */
#services{padding:160px 10vw;background:rgba(0,0,0,.2)}
.services-header{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:80px}
.services-title{font-family:'Playfair Display',serif;font-size:clamp(36px,5vw,64px);font-weight:300;line-height:1.05}
.services-title em{font-style:italic}
.services-sub{font-size:11px;color:rgba(244,241,235,.35);max-width:260px;line-height:1.9;text-align:right}
.services-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:1px;background:rgba(244,241,235,.05)}
.service-card{
  background:#071510;padding:56px 44px;position:relative;overflow:hidden;
  cursor:none;transition:background .5s;
}
.service-card::after{
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg,transparent,rgba(201,169,110,.05));
  opacity:0;transition:opacity .5s;
}
.service-card:hover{background:#0a1e12}
.service-card:hover::after{opacity:1}
.service-num{font-family:'Playfair Display',serif;font-size:10px;letter-spacing:.3em;color:rgba(244,241,235,.18);margin-bottom:44px;display:block}
.service-icon{width:40px;height:1px;background:var(--gold);margin-bottom:28px;transition:width .5s cubic-bezier(.16,1,.3,1)}
.service-card:hover .service-icon{width:72px}
.service-name{font-family:'Playfair Display',serif;font-size:clamp(22px,2.5vw,34px);font-weight:300;line-height:1.1;margin-bottom:16px}
.service-name em{font-style:italic;color:rgba(244,241,235,.45)}
.service-desc{font-size:10px;line-height:2;color:rgba(244,241,235,.38);margin-bottom:40px}
.service-list{list-style:none}
.service-list li{
  font-size:9px;letter-spacing:.12em;color:rgba(244,241,235,.28);
  padding:9px 0;border-bottom:1px solid rgba(244,241,235,.04);
  display:flex;align-items:center;gap:10px;
}
.service-list li::before{content:'';display:block;width:3px;height:3px;border-radius:50%;background:var(--gold);opacity:.5;flex-shrink:0}

/* ── PORTFOLIO ── */
#portfolio{padding:160px 10vw}
.portfolio-header{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:end;margin-bottom:64px}
.portfolio-title{font-family:'Playfair Display',serif;font-size:clamp(36px,5vw,64px);font-weight:300;line-height:1.05}
.portfolio-title em{font-style:italic}

/* Tab system — functional */
.portfolio-tabs{display:flex;flex-direction:column;gap:8px;justify-content:flex-end;align-items:flex-end}
.tab-btn{
  font-size:8px;letter-spacing:.22em;text-transform:uppercase;
  color:rgba(244,241,235,.25);background:none;border:none;
  cursor:none;padding:6px 0;position:relative;transition:color .3s;
  display:flex;align-items:center;gap:10px;
}
.tab-btn::after{
  content:'';display:block;
  height:1px;width:0;background:var(--cream);
  transition:width .4s cubic-bezier(.16,1,.3,1);
}
.tab-btn.active,.tab-btn:hover{color:var(--cream)}
.tab-btn.active::after{width:28px}
.tab-btn:hover::after{width:16px}

/* Portfolio panels */
.portfolio-panel{display:none}
.portfolio-panel.active{display:block}

/* Film / Reel grid */
.reel-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}
.reel-item{
  position:relative;overflow:hidden;cursor:none;
  background:rgba(244,241,235,.04);aspect-ratio:9/16;
  transition:transform .4s cubic-bezier(.16,1,.3,1);
}
.reel-item:first-child{grid-column:span 2;aspect-ratio:16/9}
.reel-item:hover{transform:scale(.98)}

/* mockup frame — "phone/monitor" border */
.reel-frame{
  position:absolute;inset:0;
  border:1px solid rgba(244,241,235,.06);
  pointer-events:none;z-index:2;
}
/* play button */
.reel-play{
  position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);z-index:3;
  width:48px;height:48px;border-radius:50%;
  border:1px solid rgba(244,241,235,.3);
  display:flex;align-items:center;justify-content:center;
  opacity:0;transition:opacity .3s;
  background:rgba(7,21,16,.4);backdrop-filter:blur(8px);
}
.reel-play svg{width:14px;height:14px;fill:var(--cream);margin-left:3px}
.reel-item:hover .reel-play{opacity:1}
.reel-info{
  position:absolute;bottom:0;left:0;right:0;z-index:3;
  padding:20px;
  background:linear-gradient(to top,rgba(7,21,16,.85) 0%,transparent 100%);
  transform:translateY(8px);opacity:0;
  transition:all .4s cubic-bezier(.16,1,.3,1);
}
.reel-item:hover .reel-info{transform:none;opacity:1}
.reel-client{font-size:7px;letter-spacing:.22em;text-transform:uppercase;color:rgba(244,241,235,.38);margin-bottom:4px}
.reel-name{font-family:'Playfair Display',serif;font-size:15px;font-weight:300;color:var(--cream)}
.reel-type{font-size:8px;letter-spacing:.14em;color:var(--gold);margin-top:3px}
/* Placeholder BG colors */
.reel-bg-1{background:radial-gradient(ellipse at 30% 50%,rgba(27,74,46,.5),rgba(7,21,16,.95))}
.reel-bg-2{background:radial-gradient(ellipse at 60% 40%,rgba(141,136,128,.18),rgba(7,21,16,.95))}
.reel-bg-3{background:radial-gradient(ellipse at 40% 60%,rgba(201,169,110,.1),rgba(7,21,16,.95))}
.reel-bg-4{background:radial-gradient(ellipse at 70% 30%,rgba(27,74,46,.4),rgba(7,21,16,.95))}
.reel-bg-5{background:radial-gradient(ellipse at 50% 70%,rgba(201,169,110,.12),rgba(7,21,16,.95))}

/* IG mockup grid */
.ig-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px}
.ig-card{
  position:relative;aspect-ratio:4/5;overflow:hidden;cursor:none;
  background:rgba(244,241,235,.04);
}
.ig-card:hover .reel-info{transform:none;opacity:1}
.ig-overlay{
  position:absolute;inset:0;
  background:linear-gradient(to top,rgba(7,21,16,.6) 0%,transparent 60%);
  opacity:0;transition:opacity .4s;
}
.ig-card:hover .ig-overlay{opacity:1}
.ig-info{
  position:absolute;bottom:0;left:0;right:0;padding:16px;z-index:2;
  opacity:0;transform:translateY(6px);
  transition:all .35s cubic-bezier(.16,1,.3,1);
}
.ig-card:hover .ig-info{opacity:1;transform:none}
.ig-handle{font-size:8px;letter-spacing:.15em;color:rgba(244,241,235,.6)}
.ig-metric{font-family:'Playfair Display',serif;font-size:18px;color:var(--cream)}
.ig-bg-1{background:radial-gradient(ellipse at 40% 40%,rgba(42,102,66,.4),rgba(7,21,16,.95))}
.ig-bg-2{background:radial-gradient(ellipse at 60% 60%,rgba(141,136,128,.2),rgba(7,21,16,.95))}
.ig-bg-3{background:radial-gradient(ellipse at 30% 70%,rgba(201,169,110,.14),rgba(7,21,16,.95))}
.ig-bg-4{background:radial-gradient(ellipse at 70% 30%,rgba(27,74,46,.3),rgba(7,21,16,.95))}

/* Web portfolio */
.web-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.web-card{position:relative;overflow:hidden;cursor:none;background:rgba(244,241,235,.04)}
.web-card:first-child{grid-column:span 2;aspect-ratio:16/6}
.web-card:not(:first-child){aspect-ratio:16/9}
/* Browser chrome mockup */
.browser-chrome{
  background:rgba(244,241,235,.05);
  border-bottom:1px solid rgba(244,241,235,.06);
  padding:10px 14px;display:flex;align-items:center;gap:6px;
}
.b-dot{width:7px;height:7px;border-radius:50%}
.b-dot:nth-child(1){background:rgba(255,100,100,.3)}
.b-dot:nth-child(2){background:rgba(255,200,50,.3)}
.b-dot:nth-child(3){background:rgba(50,200,100,.3)}
.browser-url{
  margin-left:12px;font-size:8px;letter-spacing:.06em;
  color:rgba(244,241,235,.2);font-family:'Jost',sans-serif;
}
.browser-content{
  flex:1;position:relative;overflow:hidden;
}
.web-card{display:flex;flex-direction:column}
.web-preview{flex:1;position:relative;overflow:hidden}
.web-overlay{
  position:absolute;inset:0;
  background:linear-gradient(to top,rgba(7,21,16,.75) 0%,transparent 50%);
  opacity:0;transition:opacity .4s;display:flex;align-items:flex-end;padding:20px;
}
.web-card:hover .web-overlay{opacity:1}
.web-info .web-client{font-size:7px;letter-spacing:.2em;text-transform:uppercase;color:rgba(244,241,235,.4);margin-bottom:4px}
.web-info .web-name{font-family:'Playfair Display',serif;font-size:18px;font-weight:300;color:var(--cream)}
.web-info .web-tag{font-size:8px;color:var(--gold);margin-top:3px}
.web-bg-1{background:radial-gradient(ellipse at 50% 50%,rgba(27,74,46,.4),rgba(7,21,16,.95))}
.web-bg-2{background:radial-gradient(ellipse at 30% 40%,rgba(42,102,66,.3),rgba(7,21,16,.95))}
.web-bg-3{background:radial-gradient(ellipse at 70% 60%,rgba(201,169,110,.1),rgba(7,21,16,.95))}

/* Placeholder "incoming" notice */
.assets-notice{
  margin-top:32px;padding:20px 24px;
  border:1px solid rgba(244,241,235,.06);
  display:flex;align-items:center;gap:12px;
}
.assets-dot{width:5px;height:5px;border-radius:50%;background:var(--gold);flex-shrink:0;animation:badgePulse 2s ease-in-out infinite}
.assets-txt{font-size:9px;letter-spacing:.14em;color:rgba(244,241,235,.28)}

/* ── TESTIMONIAL ── */
#testimonial{
  padding:100px 10vw;text-align:center;
  border-top:1px solid rgba(244,241,235,.05);border-bottom:1px solid rgba(244,241,235,.05);
}
